{
  "name": "survey-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Express + Prisma backend for Survey App",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "prisma generate && tsc && tsc-alias --project tsconfig.json",
    "start": "npm run build && node dist/backend/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,js}\" --quiet",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix"
  },
  "keywords": [
    "survey",
    "express",
    "prisma",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.17",
    "@types/node": "^22.15.29",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "pg": "^8.16.3",
    "prisma": "^6.9.0",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.1.0",
    "@testcontainers/postgresql": "^11.8.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.5.0",
    "supertest": "^6.3.3",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "vitest": "^1.4.7"
  }
}
